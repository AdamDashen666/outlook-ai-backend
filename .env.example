PORT=3000
PUBLIC_BASE_URL=https://your-backend.example.com

# Microsoft Entra app registration
MS_CLIENT_ID=replace_with_client_id
MS_CLIENT_SECRET=replace_with_client_secret
MS_REDIRECT_URI=https://your-backend.example.com/auth/callback
MS_SCOPES=offline_access User.Read Mail.ReadWrite

# OpenAI-compatible AI API
AI_BASE_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=replace_with_ai_key
AI_MODEL=gpt-4o-mini

# APNs push notification settings
APNS_TEAM_ID=replace_with_team_id
APNS_KEY_ID=replace_with_key_id
APNS_BUNDLE_ID=com.laodeng.outlookaisummary
APNS_KEY_FILE=./AuthKey_replace.p8
APNS_PRODUCTION=false

# Cleanup policy
AUTO_DELETE_ENABLED=true
DELETE_AFTER_DAYS=30
PERMANENT_DELETE_AFTER_DAYS=7
